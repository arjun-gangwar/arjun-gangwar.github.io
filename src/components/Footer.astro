---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer>
  <p class="muted">
    © {year} {SITE_TITLE} · <a href="/rss.xml">RSS</a>
  </p>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
  }

  p {
    max-width: 44rem;
    margin: 0 auto;
    padding: 1rem 1.25rem;
    font-size: 0.85rem;
  }
</style>
