<div id="search"></div>

{/* Pagefind assets are generated by `pagefind --site dist` at build time,
    so search only works in the built site (npm run build && npm run preview
    or the deployed site), never in `npm run dev`. */}
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.PagefindUI) {
      new window.PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      });
    } else {
      // Dev mode: the script above 404'd because no index exists yet.
      document.getElementById('search').innerHTML =
        '<p class="muted" style="font-size:0.85rem">Search is only available in the built site (npm run build && npm run preview).</p>';
    }
  });
</script>

<style is:global>
  #search {
    margin: 1.25rem 0;
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--bg-muted);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: inherit;
  }
</style>
