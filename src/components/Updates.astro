---
import { UPDATES } from '../data/updates';

const fmt = new Intl.DateTimeFormat('en', { month: 'short', year: 'numeric' });
---

<ul class="updates">
  {
    UPDATES.map(({ date, html }) => (
      <li>
        <span class="date muted">{fmt.format(new Date(date))}</span>
        <span set:html={html} />
      </li>
    ))
  }
</ul>

<style>
  .updates {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .updates li {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .date {
    flex: 0 0 5rem;
    font-size: 0.85rem;
    padding-top: 0.12rem;
    white-space: nowrap;
  }
</style>
